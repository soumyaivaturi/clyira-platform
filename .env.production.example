# Clyira — Production Environment Variables
# Copy these into your Render dashboard (API service) and Vercel dashboard (frontend)

# ── FastAPI / Render ──────────────────────────────────────────────────────────

# From Supabase project: Settings → Database → Connection string (URI mode, use pooler for serverless)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Generate: openssl rand -hex 32
SECRET_KEY=<your-secret-key>

# Your Google AI Studio key
GEMINI_API_KEY=<your-gemini-api-key>

# From Supabase project: Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=documents

# Set to your Vercel app URL (e.g. https://clyira.vercel.app)
CORS_ORIGINS=https://<your-vercel-app>.vercel.app

ENVIRONMENT=production
DEBUG=false

# ── Next.js / Vercel ──────────────────────────────────────────────────────────

# Set this in the Vercel dashboard as API_URL (not NEXT_PUBLIC — it's server-side only)
# Value: your Render web service URL, e.g. https://clyira-api.onrender.com
API_URL=https://clyira-api.onrender.com
